<%- include('partials/header', { seo, pageId, totalOrders, completedOrders, activeNow, reviews, currentYear, recentOrders }) %>

<!-- Page Hero -->
<section class="page-hero">
  <div class="container">
    <div class="hero-badges" style="margin-bottom:1rem;">
      <span class="badge badge-lg">★ Atlas Trade Group</span>
      <span class="badge badge-lg">✓ Est. 2019</span>
      <span class="badge badge-lg">₿ BTC Only</span>
      <span class="badge badge-lg">✓ <%= product.name %></span>
    </div>
    <h1><span class="highlight"><%= product.name %></span></h1>
    <p class="hero-subtitle" style="color:var(--gold);font-size:1.1rem;font-weight:600;margin-bottom:0.5rem;"><%= product.subtitle %></p>
    <p class="hero-desc"><%= product.longDesc %></p>
    <div class="hero-badges">
      <span class="badge badge-lg">✓ Fresh Batch <%= new Date().toLocaleString('en-US', { month: 'long', year: 'numeric' }) %></span>
      <span class="badge badge-lg">✓ Instant Digital Delivery</span>
      <span class="badge badge-lg">✓ Replacement Within 24h</span>
    </div>
  </div>
</section>

<!-- Main Content -->
<section class="section">
  <div class="container">

    <!-- Pricing Grid + Sidebar -->
    <div class="product-grid">
      <div>
        <!-- Pricing Cards -->
        <div class="section-subheader">
          <h2>💰 Pricing — <%= product.priceLabel %></h2>
        </div>
        <div class="product-cards">
          <% product.variants.forEach((variant) => { %>
          <div class="card product-card">
            <div class="card-badge"><%= variant.label %></div>
            <div class="card-body">
              <div class="card-price">
                <span class="price-currency">$</span>
                <span class="price-amount"><%= variant.price %></span>
              </div>
              <% if (variant.note) { %>
              <p style="font-size:0.75rem;color:var(--text-dim);text-align:center;margin-bottom:0.75rem;"><%= variant.note %></p>
              <% } %>
              <div class="card-meta">
                <span class="meta-item">✓ Fresh & Valid</span>
                <span class="meta-item">✓ Instant Delivery</span>
                <span class="meta-item">✓ 24h Replacement</span>
              </div>
              <button class="btn btn-primary btn-block" onclick="openCheckout('<%= product.id %>', '<%= variant.label %>', <%= variant.price %>)">
                Buy Now — $<%= variant.price %>
              </button>
            </div>
          </div>
          <% }) %>
        </div>

        <!-- Crypto Off-Ramp Details -->
        <% if (product.offramp) { %>
        <div class="section-subheader" style="margin-top:2rem;">
          <h2>🏦 Crypto Off-Ramp Service</h2>
          <p style="font-size:0.82rem;color:var(--text-secondary);margin-top:0.3rem;">Convert crypto to fiat — <strong style="color:#fff;">Min $2,500 / Max $50,000</strong> per transaction. Fee: <strong style="color:var(--gold);"><%= product.offramp.fee %></strong></p>
        </div>
        
        <div class="card" style="background:var(--bg-elevated);border:1px solid var(--border);border-radius:var(--radius-md);padding:1.5rem;margin-bottom:1.5rem;">
          <p style="font-size:0.82rem;color:var(--text-dim);margin-bottom:1rem;"><%= product.offramp.feeNote %></p>
          
          <div class="offramp-calculator">
            <h4 style="color:#fff;margin-bottom:1rem;">🧮 Calculate Your Fee & Place Order</h4>
            
            <div class="offramp-row">
              <div class="offramp-field">
                <label>Amount to Convert ($)</label>
                <div class="offramp-input-group">
                  <input type="number" id="offrampAmount" class="form-input" min="2500" max="50000" value="2500" step="100" oninput="calcOfframpFee()" onchange="calcOfframpFee()">
                  <div class="offramp-presets" id="offrampPresets">
                    <button type="button" class="preset-btn" onclick="setOfframpAmount(2500)">$2.5k</button>
                    <button type="button" class="preset-btn" onclick="setOfframpAmount(5000)">$5k</button>
                    <button type="button" class="preset-btn" onclick="setOfframpAmount(10000)">$10k</button>
                    <button type="button" class="preset-btn" onclick="setOfframpAmount(25000)">$25k</button>
                    <button type="button" class="preset-btn" onclick="setOfframpAmount(50000)">$50k</button>
                  </div>
                </div>
              </div>
              <div class="offramp-field">
                <label>Receiving Method</label>
                <select id="offrampMethod" class="form-input" onchange="calcOfframpFee()">
                  <% product.offramp.receivingMethods.forEach(m => { %>
                  <option value="<%= m.method %>" data-fee="<%= m.feePct %>"><%= m.method %> — <%= m.feePct %>% fee</option>
                  <% }) %>
                </select>
              </div>
            </div>
            
            <div class="offramp-row">
              <div class="offramp-field">
                <label>Currency</label>
                <select id="offrampCurrency" class="form-input">
                  <option value="USD">🇺🇸 USD — US Dollar</option>
                  <option value="GBP">🇬🇧 GBP — British Pound</option>
                  <option value="EUR">🇪🇺 EUR — Euro</option>
                  <option value="CAD">🇨🇦 CAD — Canadian Dollar</option>
                  <option value="AUD">🇦🇺 AUD — Australian Dollar</option>
                </select>
              </div>
              <div class="offramp-field">
                <label>Country</label>
                <select id="offrampCountry" class="form-input">
                  <% product.offramp.countries.forEach(c => { %>
                  <option value="<%= c %>"><%= c %></option>
                  <% }) %>
                </select>
              </div>
            </div>
            
            <div class="offramp-fee-box" id="offrampFeeBox">
              <div class="offramp-fee-row">
                <span>Transfer Amount:</span>
                <span class="offramp-val" id="offrampTransferAmt">$2,500.00</span>
              </div>
              <div class="offramp-fee-row">
                <span>Fee (<span id="offrampFeePct">18</span>%):</span>
                <span class="offramp-val" id="offrampTotalFee">$450.00</span>
              </div>
              <div class="offramp-fee-row total">
                <span>Total in BTC:</span>
                <span class="offramp-val" id="offrampBtcEq">≈ 0.0047 BTC</span>
              </div>
              <div class="offramp-fee-row">
                <span>You Receive:</span>
                <span class="offramp-val" style="color:var(--green);" id="offrampReceiveAmt">$2,050.00</span>
              </div>
            </div>
            
            <div class="offramp-divider"></div>
            
            <h4 style="color:#fff;margin-bottom:0.75rem;">🏧 Your Banking Details</h4>
            <div class="offramp-row">
              <div class="offramp-field">
                <label>Full Name on Account</label>
                <input type="text" id="offrampName" class="form-input" placeholder="John Michael Doe" required>
              </div>
              <div class="offramp-field">
                <label>Bank Name</label>
                <input type="text" id="offrampBank" class="form-input" placeholder="Chase, Barclays, RBC, etc." required>
              </div>
            </div>
            <div class="offramp-row">
              <div class="offramp-field">
                <label>Account Number</label>
                <input type="text" id="offrampAccount" class="form-input" placeholder="Account / IBAN number" required>
              </div>
              <div class="offramp-field">
                <label>Routing / Sort Code / IBAN</label>
                <input type="text" id="offrampRouting" class="form-input" placeholder="Routing number / Sort Code / SWIFT" required>
              </div>
            </div>
            <div class="offramp-row">
              <div class="offramp-field">
                <label>Bank Branch (City, Country)</label>
                <input type="text" id="offrampBranch" class="form-input" placeholder="e.g. London, United Kingdom" required>
              </div>
              <div class="offramp-field">
                <label>Email for Updates</label>
                <input type="email" id="offrampEmail" class="form-input" placeholder="your@email.com" required>
              </div>
            </div>

            <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius-sm);padding:1rem;margin:1rem 0;">
              <p style="font-size:0.78rem;color:var(--text-dim);line-height:1.7;"><%= product.offramp.note %></p>
            </div>
            
            <button class="btn btn-primary btn-lg btn-block" onclick="submitOfframp()" id="offrampBtn">
              💰 Pay Fee: <span id="offrampBtnFee">$450.00</span> (<span id="offrampBtnBtc">≈ 0.0047 BTC</span>) — Process Transfer →
            </button>
          </div>
        </div>
        
        <style>
          .offramp-calculator { max-width: 640px; }
          .offramp-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
          .offramp-field label { display: block; font-size: 0.82rem; color: var(--text-secondary); margin-bottom: 0.3rem; }
          .field-hint { display: block; font-size: 0.7rem; color: var(--text-dim); margin-top: 0.2rem; }
          .offramp-fee-box { background: var(--bg-card); border: 1px solid var(--gold); border-radius: var(--radius-sm); padding: 1rem; margin: 1rem 0; }
          .offramp-fee-row { display: flex; justify-content: space-between; padding: 0.35rem 0; font-size: 0.85rem; color: var(--text-secondary); }
          .offramp-fee-row.total { border-top: 1px solid var(--border); margin-top: 0.3rem; padding-top: 0.7rem; font-size: 1rem; font-weight: 700; color: var(--gold); }
          .offramp-val { font-family: var(--font-mono); }
          .offramp-divider { border-top: 1px solid var(--border); margin: 1.25rem 0; }
          .offramp-input-group { display: flex; flex-direction: column; gap: 0.5rem; }
          .offramp-presets { display: flex; gap: 0.35rem; flex-wrap: wrap; }
          .preset-btn { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 0.3rem 0.6rem; font-size: 0.75rem; color: var(--text-secondary); cursor: pointer; transition: all 0.2s; }
          .preset-btn:hover { border-color: var(--gold); color: var(--gold); background: rgba(255,215,0,0.08); }
          @media (max-width: 600px) { .offramp-row { grid-template-columns: 1fr; } }
        </style>
        <% } %>

        <!-- Bulk Pricing (with optional country selector) -->
        <% if (product.bulkByCountry) { %>
        <div class="section-subheader" style="margin-top:2rem;">
          <h2>📦 Bulk / Wholesale Pricing</h2>
          <div style="display:flex;align-items:center;gap:0.5rem;margin-top:0.5rem;">
            <label style="font-size:0.82rem;color:var(--text-secondary);">Region:</label>
            <select id="bulkCountry" class="form-input" style="width:auto;padding:0.4rem 0.7rem;font-size:0.82rem;" onchange="switchBulkCountry()">
              <% Object.keys(product.bulkByCountry).forEach(c => { %>
              <option value="<%= c %>" <%= c === 'US' ? 'selected' : '' %>><%= c %></option>
              <% }) %>
            </select>
          </div>
        </div>
        <div id="bulkGridContainer">
          <% const defaultCountry = 'US'; %>
          <% if (product.bulkByCountry[defaultCountry]) { %>
          <div class="bulk-grid" id="bulkGrid">
            <% product.bulkByCountry[defaultCountry].forEach((bp) => { %>
            <div class="bulk-card">
              <div class="bulk-qty"><%= bp.qty %></div>
              <div class="bulk-label"><%= bp.label %></div>
              <div class="bulk-price">$<%= bp.price.toLocaleString() %></div>
              <div class="bulk-per"><%= bp.per %></div>
              <button class="btn btn-sm btn-outline" onclick="openCheckout('<%= product.id %>', '<%= bp.label %>', <%= bp.price %>)">Buy Now</button>
            </div>
            <% }) %>
          </div>
        <% } %>
        <!-- Store all country data for JS switching -->
        <script>
          window.bulkByCountry = <%- JSON.stringify(product.bulkByCountry) %>;
        </script>
        </div>
        <% } else if (product.bulkPricing) { %>
        <div class="section-subheader" style="margin-top:2rem;">
          <h2>📦 Bulk / Wholesale Pricing</h2>
        </div>
        <div class="bulk-grid">
          <% product.bulkPricing.forEach((bp) => { %>
          <div class="bulk-card">
            <div class="bulk-qty"><%= bp.qty %></div>
            <div class="bulk-label"><%= bp.label %></div>
            <div class="bulk-price">$<%= bp.price.toLocaleString() %></div>
            <div class="bulk-per"><%= bp.per %></div>
            <button class="btn btn-sm btn-outline" onclick="openCheckout('<%= product.id %>', '<%= bp.label %>', <%= bp.price %>)">Buy Now</button>
          </div>
          <% }) %>
        </div>
        <% } %>

        <!-- SSN DOB DL Only Packs (Fullz page) -->
        <% if (product.ssnPacks) { %>
        <div class="section-subheader" style="margin-top:2rem;">
          <h2>🆔 SSN DOB DL Only — No CC Data</h2>
          <p style="font-size:0.82rem;color:var(--text-secondary);margin-top:0.3rem;">Identity packages with SSN, DOB, DL, address, phone, email. No credit card details. Bulk packs only.</p>
        </div>
        <div class="bulk-grid">
          <% product.ssnPacks.forEach((sp) => { %>
          <div class="bulk-card" style="border-color:rgba(255,255,255,0.1);">
            <div class="bulk-qty"><%= sp.qty %></div>
            <div class="bulk-label"><%= sp.label %></div>
            <div class="bulk-price">$<%= sp.price.toLocaleString() %></div>
            <div class="bulk-per"><%= sp.per %></div>
            <button class="btn btn-sm btn-outline" onclick="openCheckout('<%= product.id %>', '<%= sp.label %>', <%= sp.price %>)">Buy Now</button>
          </div>
          <% }) %>
        </div>
        <p style="font-size:0.78rem;color:var(--text-dim);margin-top:0.5rem;">⚠️ SSN DOB DL packs contain identity data only — no credit card numbers. Format: NAME|ADDRESS|DOB|DL|SSN|PHONE|EMAIL. Delivered via email.</p>
        <% } %>

        <!-- Sample Data -->
        <% if (product.samples) { %>
        <div class="section-subheader" style="margin-top:2rem;">
          <h2>📋 Sample Data</h2>
        </div>
        <% product.samples.forEach((sample, idx) => { %>
        <div class="sample-card">
          <div class="sample-header">
            <strong><%= sample.label %></strong>
            <button class="btn btn-sm btn-secondary" onclick="copySample(<%= idx %>)">📋 Copy</button>
          </div>
          <pre class="sample-data" id="sample<%= idx %>"><code><%= sample.data %></code></pre>
        </div>
        <% }) %>
        <% } %>

        <!-- UK/CA Format Clarification (Fullz page) -->
        <% if (product.id === 'fullz') { %>
        <div class="format-note-card" style="background:var(--bg-elevated);border:1px solid var(--border);border-radius:var(--radius-sm);padding:1rem;margin-top:1.5rem;">
          <h4 style="margin-bottom:0.5rem;color:#fff;">🌍 UK & Canada Fullz Format</h4>
          <div style="font-size:0.82rem;color:var(--text-secondary);line-height:1.8;">
            <p><strong style="color:#fff;">UK Format:</strong> <code class="mono" style="color:var(--green);font-size:0.75rem;">CC#|EXP|CVV|NAME|ADDRESS|POSTCODE|DOB|DL|NINO|SORT CODE|ACCT|PHONE|EMAIL|IP</code></p>
            <p style="margin-top:0.3rem;">UK fullz include <strong style="color:#fff;">National Insurance Number (NINO)</strong> instead of SSN, and <strong style="color:#fff;">Sort Code + Account Number</strong> instead of routing/account.</p>
            <p style="margin-top:0.8rem;"><strong style="color:#fff;">CA Format:</strong> <code class="mono" style="color:var(--green);font-size:0.75rem;">CC#|EXP|CVV|NAME|ADDRESS|POSTAL CODE|DOB|DL|SIN|INSTITUTION#|ACCT|PHONE|EMAIL|IP</code></p>
            <p style="margin-top:0.3rem;">Canada fullz include <strong style="color:#fff;">Social Insurance Number (SIN)</strong> and <strong style="color:#fff;">Institution Number + Account Number</strong> (instead of routing). Province included in address.</p>
          </div>
        </div>
        <% } %>

        <!-- BINS Table -->
        <% if (product.bins) { %>
        <div class="section-subheader" style="margin-top:2rem;">
          <h2>🔢 Available BINS</h2>
        </div>
        <div class="table-wrap">
          <table class="data-table">
            <thead>
              <tr><th>BIN</th><th>Type</th><th>Bank</th></tr>
            </thead>
            <tbody>
              <% product.bins.forEach((b) => { %>
              <tr><td class="mono"><%= b.bin %></td><td><%= b.type %></td><td><%= b.bank %></td></tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>

        <!-- Inventory Table (Bank Logs) -->
        <% if (product.inventory) { %>
        <div class="section-subheader" style="margin-top:2rem;">
          <h2>🏦 Current Inventory — Fresh Batch #ATLAS-0626-01</h2>
        </div>
        <div class="table-wrap">
          <table class="data-table">
            <thead>
              <tr><th>Bank / Account Type</th><th>Balance Range</th><th>Available</th><th>Region</th></tr>
            </thead>
            <tbody>
              <% product.inventory.forEach((inv) => { %>
              <tr>
                <td><%= inv.bank %></td>
                <td class="mono" style="color:var(--gold);"><%= inv.balance %></td>
                <td>x<%= inv.avail %></td>
                <td><%= inv.country %></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>

        <!-- Data Fields -->
        <% if (product.fields) { %>
        <div class="section-subheader" style="margin-top:2rem;">
          <h2>📄 Included Fields</h2>
        </div>
        <div class="data-format">
          <% product.fields.forEach((f) => { %>
          <span class="data-tag"><%= f %></span>
          <% }) %>
        </div>
        <% } %>
      </div>

      <!-- Sidebar -->
      <div class="product-sidebar">
        <div class="card info-card">
          <h3>🛡️ Why Buy From Us</h3>
          <ul class="feature-list">
            <li>✓ Atlas Trade Group — Est. 2019</li>
            <li>✓ 2,470+ orders completed</li>
            <li>✓ Fresh stock updated weekly</li>
            <li>✓ 24h replacement policy</li>
            <li>✓ Wholesale pricing available</li>
            <li>✓ Verified on multiple boards</li>
          </ul>
        </div>

        <div class="card info-card">
          <h3>📋 Product Details</h3>
          <div class="detail-list">
            <div class="detail-row-mini">
              <span class="dl-label">Category</span>
              <span class="dl-value"><%= product.name %></span>
            </div>
            <div class="detail-row-mini">
              <span class="dl-label">Starting Price</span>
              <span class="dl-value" style="color:var(--gold);">$<%= product.price %></span>
            </div>
            <div class="detail-row-mini">
              <span class="dl-label">Delivery</span>
              <span class="dl-value" style="color:var(--green);font-size:0.75rem;"><%= product.deliveryTime || 'Instant' %></span>
            </div>
            <div class="detail-row-mini">
              <span class="dl-label">Payment</span>
              <span class="dl-value">₿ BTC Only</span>
            </div>
          </div>
        </div>

        <div class="card info-card">
          <h3>📞 Contact</h3>
          <div class="contact-sidebar">
            <p>Telegram: <a href="https://t.me/efullz">@efullz</a></p>
            <p>Phone: +1 208 795 8997</p>
            <p>Email: ru.vendors5@gmail.com</p>
            <p style="font-size:0.7rem;color:var(--text-dim);margin-top:0.5rem;">PGP: 3A4B 7C8D 9E0F 1A2B 3C4D 5E6F 7A8B 9C0D 1E2F 3A4B</p>
          </div>
          <a href="https://t.me/efullz" class="btn btn-primary btn-block" target="_blank" style="margin-top:0.75rem;">📱 Contact @efullz</a>
        </div>

        <div class="card info-card">
          <h3>📜 Terms</h3>
          <p style="font-size:0.82rem;color:var(--text-secondary);line-height:1.7;"><%= product.terms %></p>
          <p style="font-size:0.78rem;color:var(--text-dim);margin-top:0.75rem;">BTC Only — Come BTC Ready. Min order $100 (new clients). Replacement within 24h for dead items. No refunds — replacement only. Serious buyers only.</p>
        </div>

        <!-- Reviews -->
        <div class="card reviews-card">
          <h3>⭐ What Buyers Say</h3>
          <% reviews.slice(0, 2).forEach(r => { %>
          <div class="review-item">
            <div class="review-stars"><%= '★'.repeat(r.rating) %><%= '☆'.repeat(5 - r.rating) %></div>
            <p class="review-text">"<%= r.text.slice(0, 120) %>..."</p>
            <div class="review-footer">
              <span class="review-date"><%= r.date %></span>
              <span class="review-verified">✓ <%= r.product %></span>
            </div>
          </div>
          <% }) %>
          <a href="/#reviews" class="btn btn-secondary btn-block" style="margin-top:0.75rem;">Read All Reviews</a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- SEO Content Section -->
<section class="section section-dark">
  <div class="container">
    <div class="seo-content">
      <h2>Buy <%= product.name %> Online — Trusted Since 2019</h2>
      <p>Looking for a reliable <strong><%= product.tags ? product.tags.slice(0, 3).join(', ') : product.name.toLowerCase() %></strong> vendor? Atlas Trade Group has been operating since 2019, providing premium carding and financial services to buyers worldwide. Our <%= product.name.toLowerCase() %> are sourced fresh, verified before delivery, and backed by a 24-hour replacement policy.</p>
      <p>We accept <strong>Bitcoin (BTC) only</strong>. All payments are processed automatically through secure channels. No registration required — simply choose your product, submit your order, and pay. Delivery is instant for digital products.</p>
      <p>With <strong>2,470+ orders completed</strong> and a 97.8% success rate, we are one of the most trusted vendors in the space. Contact us on Telegram <strong>@efullz</strong> for bulk pricing, custom requests, or any questions.</p>
      <div class="seo-tags">
        <% if (product.tags) { product.tags.forEach(t => { %>
        <span class="seo-tag"><%= t %></span>
        <% }) } %>
      </div>
    </div>
  </div>
</section>

<!-- Trust Section -->
<section class="section">
  <div class="container">
    <div class="trust-grid">
      <div class="trust-card">
        <div class="tc-icon">🏆</div>
        <h3>Established 2019</h3>
        <p>Atlas Trade Group has been operating since 2019. We're not new — our reputation speaks for itself.</p>
      </div>
      <div class="trust-card">
        <div class="tc-icon">⚡</div>
        <h3>Instant Delivery</h3>
        <p>Digital products delivered within minutes of payment confirmation. Automated system, no waiting.</p>
      </div>
      <div class="trust-card">
        <div class="tc-icon">🔄</div>
        <h3>24h Replacement</h3>
        <p>Dead item? Send proof within 24 hours and get a free replacement. No questions asked.</p>
      </div>
      <div class="trust-card">
        <div class="tc-icon">₿</div>
        <h3>BTC Only</h3>
        <p>Bitcoin only. No altcoins, no payment cards, no excuses. Come BTC ready or don't come at all.</p>
      </div>
    </div>
  </div>
</section>

<script>
// ── Product requirements for checkout form ──
window.productRequirements = <%- JSON.stringify(product.requirements || [{ key: 'email', label: 'Email for Delivery', type: 'email', placeholder: 'your@email.com', required: true }]) %>;
window.productId = '<%= product.id %>';

// ── Country-based bulk pricing switcher ──
function switchBulkCountry() {
  const sel = document.getElementById('bulkCountry');
  const container = document.getElementById('bulkGridContainer');
  if (!sel || !container || !window.bulkByCountry) return;
  
  const country = sel.value;
  const prices = window.bulkByCountry[country];
  if (!prices) return;
  
  container.innerHTML = '<div class="bulk-grid" id="bulkGrid">' +
    prices.map(bp => `
      <div class="bulk-card">
        <div class="bulk-qty">${bp.qty}</div>
        <div class="bulk-label">${bp.label}</div>
        <div class="bulk-price">$${bp.price.toLocaleString()}</div>
        <div class="bulk-per">${bp.per}</div>
        <button class="btn btn-sm btn-outline" onclick="openCheckout(window.productId, '${bp.label}', ${bp.price})">Buy Now</button>
      </div>
    `).join('') +
  '</div>';
}

// ── Off-Ramp Calculator ──
function setOfframpAmount(val) {
  const input = document.getElementById('offrampAmount');
  if (input) { input.value = val; calcOfframpFee(); }
}

function calcOfframpFee() {
  const amtInput = document.getElementById('offrampAmount');
  const methodSel = document.getElementById('offrampMethod');
  if (!amtInput || !methodSel) return;

  let amount = parseFloat(amtInput.value) || 0;
  if (amount < 2500) amount = 2500;
  if (amount > 50000) amount = 50000;
  amtInput.value = amount;

  const feePct = parseInt(methodSel.options[methodSel.selectedIndex].dataset.fee) || 18;
  // Adjust fee based on amount tiers
  let effectiveFee = feePct;
  if (amount >= 25000) effectiveFee = Math.min(feePct, 12);
  else if (amount >= 10000) effectiveFee = Math.min(feePct, 15);
  
  const totalFee = (amount * effectiveFee / 100);
  const btcRate = 95000; // approximate BTC/USD rate
  const btcEq = (totalFee / btcRate).toFixed(8);
  const receiveAmt = amount - totalFee;

  const fmt = (n) => '$' + n.toLocaleString('en-US', {minimumFractionDigits: 2});
  document.getElementById('offrampTransferAmt').textContent = fmt(amount);
  document.getElementById('offrampFeePct').textContent = effectiveFee;
  document.getElementById('offrampTotalFee').textContent = fmt(totalFee);
  document.getElementById('offrampBtcEq').textContent = '≈ ' + btcEq + ' BTC';
  document.getElementById('offrampReceiveAmt').textContent = fmt(receiveAmt);
  document.getElementById('offrampBtnFee').textContent = fmt(totalFee);
  document.getElementById('offrampBtnBtc').textContent = '≈ ' + btcEq + ' BTC';
  
  // Store for submission
  window._offrampData = { transferAmount: amount, feePct: effectiveFee, totalFee, btcEq, receiveAmt };
}

// ── Submit Off-Ramp Order ──
function submitOfframp() {
  const fields = {
    name: document.getElementById('offrampName'),
    bank: document.getElementById('offrampBank'),
    account: document.getElementById('offrampAccount'),
    routing: document.getElementById('offrampRouting'),
    branch: document.getElementById('offrampBranch'),
    email: document.getElementById('offrampEmail')
  };
  
  // Validate
  for (const [key, el] of Object.entries(fields)) {
    if (!el || !el.value.trim()) {
      alert('Please fill in all banking details fields.');
      if (el) el.focus();
      return;
    }
  }
  
  if (!window._offrampData || window._offrampData.totalFee < 10) {
    alert('Please check the amount — minimum fee is $10.');
    return;
  }

  const d = window._offrampData;
  const method = document.getElementById('offrampMethod').value;
  const currency = document.getElementById('offrampCurrency').value;
  const country = document.getElementById('offrampCountry').value;
  const fmt = (n) => '$' + n.toLocaleString('en-US', {minimumFractionDigits: 2});

  // Set custom requirements for checkout
  window.productRequirements = [
    { key: 'name', label: 'Full Name on Account', type: 'text', placeholder: 'John Doe', required: true },
    { key: 'bank', label: 'Bank Name', type: 'text', placeholder: 'Bank name', required: true },
    { key: 'account', label: 'Account Number / IBAN', type: 'text', placeholder: 'Account number', required: true },
    { key: 'routing', label: 'Routing / Sort Code', type: 'text', placeholder: 'Routing number', required: true },
    { key: 'branch', label: 'Bank Branch (City, Country)', type: 'text', placeholder: 'Branch location', required: true },
    { key: 'offramp_email', label: 'Email for Updates', type: 'email', placeholder: 'your@email.com', required: true },
  ];
  
  // Pre-fill the fields in the checkout modal
  setTimeout(() => {
    const fillField = (id, value) => {
      const el = document.getElementById(id);
      if (el) { el.value = value; }
    };
    fillField('cf_name', fields.name.value.trim());
    fillField('cf_bank', fields.bank.value.trim());
    fillField('cf_account', fields.account.value.trim());
    fillField('cf_routing', fields.routing.value.trim());
    fillField('cf_branch', fields.branch.value.trim());
    fillField('cf_offramp_email', fields.email.value.trim());
    const notes = document.getElementById('cf_notes');
    if (notes) {
      notes.value = `OFF-RAMP: Transfer ${fmt(d.transferAmount)} → ${currency} via ${method} (${country}) | Fee: ${fmt(d.totalFee)} (${d.feePct}%) | You receive: ${fmt(d.receiveAmt)} | BTC: ${d.btcEq}`;
    }
  }, 50);

  openCheckout(window.productId || 'cloned', 'Crypto Off-Ramp', d.totalFee);

  // Override the generic order summary with a detailed off-ramp breakdown
  const methodEl = document.getElementById('offrampMethod');
  const methodName = methodEl ? methodEl.options[methodEl.selectedIndex].text : '—';
  document.getElementById('orderSummary').innerHTML = `
    <div class="os-row">
      <span class="os-label">Service</span>
      <span class="os-value">Crypto Off-Ramp</span>
    </div>
    <div class="os-row">
      <span class="os-label">Transfer Amount</span>
      <span class="os-value">${fmt(d.transferAmount)}</span>
    </div>
    <div class="os-row">
      <span class="os-label">Receiving Method</span>
      <span class="os-value">${methodName.split(' — ')[0]}</span>
    </div>
    <div class="os-row">
      <span class="os-label">Currency / Country</span>
      <span class="os-value">${currency} → ${country}</span>
    </div>
    <div class="os-row">
      <span class="os-label">Fee (${d.feePct}%)</span>
      <span class="os-value">${fmt(d.totalFee)}</span>
    </div>
    <div class="os-row" style="border-top:1px solid var(--border);margin-top:0.4rem;padding-top:0.8rem;">
      <span class="os-label">Fee in BTC</span>
      <span class="os-value" style="color:var(--gold);font-weight:700;">≈ ${d.btcEq} BTC</span>
    </div>
    <div class="os-row" style="font-size:0.82rem;color:var(--green);">
      <span class="os-label">You Will Receive</span>
      <span class="os-value">${fmt(d.receiveAmt)}</span>
    </div>
  `;
}

// Initialize calculator on page load
document.addEventListener('DOMContentLoaded', () => {
  if (document.getElementById('offrampAmount')) {
    setTimeout(calcOfframpFee, 100);
  }
});

// Copy sample data to clipboard
function copySample(idx) {
  const el = document.getElementById('sample' + idx);
  if (!el) return;
  const text = el.textContent;
  navigator.clipboard.writeText(text).then(() => {
    const btn = el.parentElement.querySelector('.btn');
    const orig = btn.textContent;
    btn.textContent = '✓ Copied!';
    setTimeout(() => btn.textContent = orig, 2000);
  });
}
</script>

